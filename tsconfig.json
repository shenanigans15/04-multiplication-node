{
  "exclude": ["node_modules", "dist"],
  "include": ["src/**/*", "tests/**/*"],
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "target": "ES2020",
    "module": "CommonJS",
    "types": ["node", "jest"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
